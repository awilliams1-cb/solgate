{
  "name": "solgate",
  "version": "0.0.1",
  "description": "CLI for custom Gate monitor testing",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "solgate": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup cli/index.ts --format esm --outDir dist",
    "dev": "tsx cli/index.ts",
    "test": "vitest run"
  },
